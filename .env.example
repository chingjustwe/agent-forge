# LLM API key for chat functionality
# Get your key from: https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-...

# Base URL of the OpenAI-compatible LLM provider. Used by the runtime
# adapters AND to fetch the live model catalog from {LLM_BASE_URL}/v1/models
# at startup (so the Agents UI shows the real model list, e.g.
# deepseek-v4-flash / deepseek-v4-pro). Defaults to DeepSeek's public API.
LLM_BASE_URL=https://api.deepseek.com

# JWT signing secret — set a fixed value to persist sessions across restarts
# Generate one with: python3 -c "import uuid; print(uuid.uuid4().hex)"
JWT_SECRET=your-secret-here

# SMTP (optional — leave unset to use console sender for development)
#
# Example: Brevo (free: 300 emails/day) — https://www.brevo.com
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your-login-email
#   SMTP_PASSWORD=your-smtp-key
#   SMTP_FROM=invite@yourdomain.com
#
# Example: Gmail (free: 500 emails/day) — needs App Password
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=you@gmail.com
#
# Example: Resend (free: 100 emails/day) — https://resend.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_xxxxxxx  (your API key)
#   SMTP_FROM=invite@yourdomain.com
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# Frontend base URL (used to build invite links in emails)
APP_BASE_URL=http://localhost:5173
